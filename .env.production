# =====================================================
# Docker Compose 生产环境配置
# =====================================================

# 数据库配置
MYSQL_ROOT_PASSWORD=请设置强密码（32位以上随机字符）
DB_USER=medical_user
DB_PASSWORD=请设置强密码（32位以上随机字符）
DB_NAME=medical_ai

# JWT配置
JWT_SECRET=请设置强密码（32位以上随机字符）

# Ollama配置
# 如果Ollama在ECS上，使用：http://host.docker.internal:11434
# 如果Ollama在其他服务器，使用：http://服务器IP:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=medical-v1
OLLAMA_FALLBACK_MODEL=qwen2.5

# API基础URL（前端使用）
API_BASE_URL=http://your-ecs-ip:8080/api
