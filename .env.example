# =====================================================
# Docker Compose 配置文件（复制为 .env 使用）
# =====================================================

# 数据库配置
MYSQL_ROOT_PASSWORD=medical_root_password_2024
DB_NAME=medical_ai
DB_USER=medical_user
DB_PASSWORD=medical_password_2024

# JWT配置
JWT_SECRET=medical_jwt_secret_key_2024_please_change_in_production

# OpenAI配置（用于报告图片分析）
USE_OPENAI=true
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# DeepSeek配置（用于智能问诊）
USE_DEEPSEEK=true
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# API基础URL（前端使用）- 替换为你的ECS公网IP
API_BASE_URL=http://your-ecs-ip:8080/api

# 后端配置
NODE_ENV=production
PORT=8080
HOST=0.0.0.0
DB_HOST=mysql
DB_PORT=3306
DB_CONNECTION_LIMIT=10
JWT_EXPIRES_IN=24h

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
